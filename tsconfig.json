{
  "compilerOptions": {
    "module": "Node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2019",
    "lib": [
      "ES2019",
      "DOM"
    ],
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "allowJs": true,
    "strict": true,
    "types": [
      "node",
      "multer"
    ],
    "paths": {
      "@root/*": [
        "./*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@controller/*": [
        "./src/controller/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
    },
  },
  "include": [
    "src/**/*.ts",
    "src/types/**/*.d.ts",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}